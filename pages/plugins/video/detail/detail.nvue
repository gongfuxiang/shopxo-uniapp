        border-top-left-radius: 30rpx;
        border-top-right-radius: 30rpx;
        display: flex;
        flex-direction: column;

    }
    
    .comment-header {
        padding: 30rpx;
        box-sizing: border-box;
        border-bottom: 2rpx solid #eee;
